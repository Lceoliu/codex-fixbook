---
import "../styles/global.css";
import { withBase } from "../lib/urls.js";
import { repoUrl, submitFixUrl } from "../lib/site.js";

const { title, description, lang = "zh" } = Astro.props;
const otherLang = lang === "zh" ? "en" : "zh";
const otherLangLabel = lang === "zh" ? "English" : "中文";
const currentPath = Astro.url.pathname.replace(import.meta.env.BASE_URL, "/");
const otherPath = currentPath.replace(/^\/(zh|en)(\/|$)/, `/${otherLang}$2`);

const site = Astro.site;
const canonicalUrl = site ? new URL(Astro.url.pathname, site).href : null;
const alternateUrl = site ? new URL(withBase(otherPath), site).href : null;

const t = lang === "zh"
  ? {
      indexNav: "症状索引",
      submit: "提交修复",
      footerLine: "社区维护的 Codex CLI / 桌面端故障排查手册。数据以 YAML 存放在 GitHub 仓库，经审核后合入。",
      agentSkill: "Agent Skill"
    }
  : {
      indexNav: "Symptom index",
      submit: "Submit a fix",
      footerLine: "A community-maintained troubleshooting handbook for Codex CLI and the desktop app. Data lives as YAML in a GitHub repo and is reviewed before merge.",
      agentSkill: "Agent skill"
    };
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" href={withBase("/favicon.svg")} />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    {canonicalUrl && <link rel="alternate" hreflang={lang} href={canonicalUrl} />}
    {alternateUrl && <link rel="alternate" hreflang={otherLang} href={alternateUrl} />}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Codex Fixbook" />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="header-inner">
        <a class="brand" href={withBase(`/${lang}/`)}>Codex Fixbook</a>
        <nav class="nav" aria-label={lang === "zh" ? "主导航" : "Primary"}>
          <a href={withBase(`/${lang}/`)}>{t.indexNav}</a>
          <a class="nav-mono" href={withBase("/known-issues.json")}>known-issues.json</a>
          <a href={repoUrl}>GitHub</a>
          <a href={withBase(otherPath)} lang={otherLang}>{otherLangLabel}</a>
        </nav>
      </div>
    </header>
    <slot />
    <footer class="footer">
      <div class="footer-inner">
        <span>{t.footerLine}</span>
        <span class="footer-links">
          <a href={repoUrl}>GitHub</a>
          <a href={submitFixUrl}>{t.submit}</a>
          <a href={withBase("/known-issues.json")}>known-issues.json</a>
          <a href={`${repoUrl}/blob/main/skills/codex-fixbook/SKILL.md`}>{t.agentSkill}</a>
        </span>
      </div>
    </footer>
  </body>
</html>
