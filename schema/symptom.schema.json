{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codex-fixbook.local/schema/symptom.schema.json",
  "title": "Codex Fixbook symptom",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "title_en", "title_zh", "surfaces", "search_keywords", "cause_ids"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "title_en": { "type": "string", "minLength": 8 },
    "title_zh": { "type": "string", "minLength": 4 },
    "surfaces": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "enum": ["cli", "app", "ide", "cloud"] }
    },
    "search_keywords": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 2 }
    },
    "cause_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
      }
    }
  }
}
