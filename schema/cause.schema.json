{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codex-fixbook.local/schema/cause.schema.json",
  "title": "Codex Fixbook cause",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title_en",
    "title_zh",
    "status",
    "platforms",
    "affects_versions",
    "fixed_in",
    "diagnosis_zh",
    "workaround_zh",
    "diagnosis_en",
    "workaround_en",
    "sources",
    "verified_by",
    "last_verified",
    "last_verified_codex_version"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "title_en": { "type": "string", "minLength": 8 },
    "title_zh": { "type": "string", "minLength": 4 },
    "status": { "enum": ["active", "fixed", "partially-fixed"] },
    "platforms": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "enum": ["macos", "windows", "wsl", "linux"] }
    },
    "affects_versions": { "type": "string", "minLength": 1 },
    "fixed_in": {
      "anyOf": [
        { "type": "string", "minLength": 1 },
        { "type": "null" }
      ]
    },
    "known_offenders": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "diagnosis_zh": { "type": "string", "minLength": 20 },
    "workaround_zh": { "type": "string", "minLength": 20 },
    "diagnosis_en": { "type": "string", "minLength": 20 },
    "workaround_en": { "type": "string", "minLength": 20 },
    "sources": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "format": "uri" }
    },
    "verified_by": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "last_verified": { "type": "string", "format": "date" },
    "last_verified_codex_version": { "type": "string", "minLength": 1 }
  }
}
